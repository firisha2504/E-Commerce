// Prisma schema for FA Restaurant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @map("user_id")
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  phone        String   @unique @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  address      String?  @db.Text
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders        Order[]
  feedback      Feedback[]
  favorites     UserFavorite[]
  cartItems     CartItem[]

  @@map("users")
}

model Category {
  id          String   @id @default(uuid()) @map("category_id")
  name        String   @db.VarChar(50)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("categories")
}

model Product {
  id                    String   @id @default(uuid()) @map("product_id")
  name                  String   @db.VarChar(100)
  description           String?  @db.Text
  categoryId            String   @map("category_id")
  price                 Decimal  @db.Decimal(10, 2)
  imageUrl              String?  @map("image_url") @db.VarChar(500)
  customizationOptions  Json?    @map("customization_options")
  isAvailable           Boolean  @default(true) @map("is_available")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  category     Category       @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
  favorites    UserFavorite[]
  cartItems    CartItem[]

  @@map("products")
}

model Order {
  id                   String   @id @default(uuid()) @map("order_id")
  userId               String   @map("user_id")
  totalAmount          Decimal  @map("total_amount") @db.Decimal(10, 2)
  deliveryAddress      String   @map("delivery_address") @db.Text
  contactNumber        String   @map("contact_number") @db.VarChar(20)
  specialInstructions  String?  @map("special_instructions") @db.Text
  orderStatus          String   @default("pending") @map("order_status") @db.VarChar(20)
  deliveryStatus       String   @default("pending") @map("delivery_status") @db.VarChar(20)
  paymentStatus        String   @default("pending") @map("payment_status") @db.VarChar(20)
  orderDate            DateTime @default(now()) @map("order_date")
  deliveryDate         DateTime? @map("delivery_date")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  orderItems   OrderItem[]
  payments     Payment[]
  feedback     Feedback[]
  deliveries   OrderDelivery[]

  @@map("orders")
}

model OrderItem {
  id             String   @id @default(uuid()) @map("order_item_id")
  orderId        String   @map("order_id")
  productId      String   @map("product_id")
  quantity       Int
  unitPrice      Decimal  @map("unit_price") @db.Decimal(10, 2)
  customizations Json?
  subtotal       Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id              String    @id @default(uuid()) @map("payment_id")
  orderId         String    @map("order_id")
  paymentMethod   String    @map("payment_method") @db.VarChar(20)
  paymentStatus   String    @default("pending") @map("payment_status") @db.VarChar(20)
  transactionId   String?   @map("transaction_id") @db.VarChar(100)
  bankName        String?   @map("bank_name") @db.VarChar(50)
  referenceNumber String?   @map("reference_number") @db.VarChar(100)
  amount          Decimal   @db.Decimal(10, 2)
  paymentDate     DateTime? @map("payment_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Feedback {
  id                  String   @id @default(uuid()) @map("feedback_id")
  orderId             String   @map("order_id")
  userId              String   @map("user_id")
  rating              Int?     @db.SmallInt
  comment             String?  @db.Text
  deliveryRating      Int?     @map("delivery_rating") @db.SmallInt
  foodQualityRating   Int?     @map("food_quality_rating") @db.SmallInt
  createdAt           DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("feedback")
}

model UserFavorite {
  id           String   @id @default(uuid()) @map("favorite_id")
  userId       String   @map("user_id")
  productId    String   @map("product_id")
  timesOrdered Int      @default(1) @map("times_ordered")
  lastOrdered  DateTime @default(now()) @map("last_ordered")
  createdAt    DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("user_favorites")
}

model CartItem {
  id             String   @id @default(uuid()) @map("cart_item_id")
  userId         String   @map("user_id")
  productId      String   @map("product_id")
  quantity       Int
  customizations Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model DeliveryPersonnel {
  id          String   @id @default(uuid()) @map("delivery_id")
  name        String   @db.VarChar(100)
  phone       String   @unique @db.VarChar(20)
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")

  deliveries OrderDelivery[]

  @@map("delivery_personnel")
}

model OrderDelivery {
  id           String    @id @default(uuid()) @map("assignment_id")
  orderId      String    @map("order_id")
  deliveryId   String    @map("delivery_id")
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  pickedUpAt   DateTime? @map("picked_up_at")
  deliveredAt  DateTime? @map("delivered_at")

  order            Order             @relation(fields: [orderId], references: [id])
  deliveryPersonnel DeliveryPersonnel @relation(fields: [deliveryId], references: [id])

  @@map("order_deliveries")
}